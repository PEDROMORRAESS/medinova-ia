# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── WTS Chat ─────────────────────────────────────────────────────────────────
WTS_TOKEN=pn_...

# ─── Redis Cloud ──────────────────────────────────────────────────────────────
# Formato: redis://:PASSWORD@HOST:PORT
# Exemplo: redis://:abc123@redis-12345.c1.us-east-1.ec2.cloud.redislabs.com:12345
REDIS_URL=redis://:PASSWORD@HOST:PORT
